---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import SearchBar from "../components/SearchBar.astro";
import FilterPanel from "../components/FilterPanel.astro";
import FanficGrid from "../components/FanficGrid.astro";
import FanficModal from "../components/FanficModal.astro";

import fanficsData from "../data/fanfics.json";

const autores = [...new Set(fanficsData.map((f) => f.autor))]
  .sort((a, b) => a.localeCompare(b, "es"));

const generos = [...new Set(
  fanficsData.flatMap((f) => f.generos || [])
)].sort((a, b) => a.localeCompare(b, "es"));

const etiquetas = [...new Set(
  fanficsData.flatMap((f) => f.etiquetas || [])
)].sort((a, b) => a.localeCompare(b, "es"));

const currentPage = 1;
const totalPages = Math.ceil(fanficsData.length / 20);

const fanficsPagina = fanficsData.slice(0, 20);
---

<MainLayout title="Buscar">

  <Navbar currentPath="/buscar" />

  <main class="mx-auto max-w-7xl px-3 sm:px-6 py-8 sm:py-10">

    <!-- Hero -->
    <section
      class="mb-8 rounded-3xl border border-white/5 bg-white/[0.03] p-8 backdrop-blur-sm"
    >
      <h1 class="text-4xl font-bold tracking-tight">
        Buscar Fanfics
      </h1>

      <p class="mt-3 max-w-2xl text-slate-400">
        Explora historias por autor, género y etiquetas.
        <span class="font-semibold text-pink-300">
          {fanficsData.length}
        </span>
        fanfics disponibles.
      </p>
    </section>

    <!-- Search -->
    <section class="mb-8">
      <SearchBar
        placeholder="Buscar por título, autor o etiqueta..."
      />
    </section>

    <!-- Layout -->
    <section class="grid gap-8 lg:grid-cols-[280px_1fr]">

      <!-- Sidebar -->
      <div>
        <FilterPanel
          autores={autores}
          generos={generos}
          etiquetas={etiquetas}
        />
      </div>

      <!-- Contenido -->
      <div class="space-y-6">

        <div class="flex items-center justify-between">

          <div>
            <h2 class="text-xl font-semibold text-white">
              Resultados
            </h2>

            <p class="text-sm text-slate-400">
              {fanficsData.length} fanfics encontrados
            </p>
          </div>

        </div>

        <FanficGrid
          fanfics={fanficsPagina}
          currentPage={currentPage}
          totalPages={totalPages}
        />

      </div>

    </section>

  </main>

   <FanficModal />
</MainLayout>

<script>
  import { initLibraryButtons } from "../scripts/library.js";

  document.addEventListener("DOMContentLoaded", () => initLibraryButtons());
  document.addEventListener("astro:page-load", () => initLibraryButtons());
</script>