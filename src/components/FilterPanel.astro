---
interface Props {
  autores: string[];
  generos: string[];
  relaciones: string[];
  clasificaciones: string[];
  personajes: string[];
}

const { autores, generos, relaciones, clasificaciones, personajes } = Astro.props;
---

<aside
  class="sticky top-24 rounded-3xl border border-white/10 bg-slate-900/70 backdrop-blur-sm"
>
  <!-- Header toggle -->
  <button
    id="filter-toggle"
    class="flex w-full items-center gap-3 p-6"
    aria-expanded="true"
    aria-controls="filter-body"
  >
    <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-pink-500 to-orange-500 shrink-0">
      🎛️
    </div>
    <div class="flex-1 text-left">
      <h2 class="font-semibold text-white">Filtros</h2>
      <p class="text-xs text-slate-400">Encuentra tu próxima lectura</p>
    </div>
    <svg id="filter-chevron" xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5 text-slate-400 transition-transform duration-300"
      fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
    </svg>
  </button>

  <!-- Cuerpo plegable -->
  <div id="filter-body" class="overflow-hidden transition-all duration-300">
    <div class="space-y-5 px-6 pb-6">

      <!-- Autor (autocomplete) -->
      <div class="relative">
        <label class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Autor
        </label>
        <input
          id="filter-autor-input"
          type="text"
          placeholder="Buscar autor..."
          autocomplete="off"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50 placeholder:text-slate-500"
        />
        <input type="hidden" id="filter-autor" />
        <ul id="autor-dropdown"
          class="absolute z-50 mt-1 hidden w-full rounded-xl border border-white/10 bg-slate-900 shadow-xl overflow-hidden">
        </ul>
      </div>

      <!-- Género (autocomplete) -->
      <div class="relative">
        <label class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Género
        </label>
        <input
          id="filter-genero-input"
          type="text"
          placeholder="Buscar género..."
          autocomplete="off"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50 placeholder:text-slate-500"
        />
        <input type="hidden" id="filter-genero" />
        <ul id="genero-dropdown"
          class="absolute z-50 mt-1 hidden w-full rounded-xl border border-white/10 bg-slate-900 shadow-xl overflow-hidden">
        </ul>
      </div>

      <!-- Estado (select, sin cambios) -->
      <div>
        <label for="filter-estado"
          class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Estado
        </label>
        <select id="filter-estado"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50">
          <option value="">Todos</option>
          <option value="Completo">Completo</option>
          <option value="En Progreso">En progreso</option>
        </select>
      </div>

      <!-- Clasificación (autocomplete) -->
      <div class="relative">
        <label class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Clasificación
        </label>
        <input
          id="filter-clasificacion-input"
          type="text"
          placeholder="Ej: M, T, K..."
          autocomplete="off"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50 placeholder:text-slate-500"
        />
        <input type="hidden" id="filter-clasificacion" />
        <ul id="clasificacion-dropdown"
          class="absolute z-50 mt-1 hidden w-full rounded-xl border border-white/10 bg-slate-900 shadow-xl overflow-hidden">
        </ul>
      </div>

      <!-- Personajes (autocomplete + tags) -->
      <div class="relative">
        <label class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Personajes
        </label>
        <input
          id="filter-personaje-input"
          type="text"
          placeholder="Buscar personaje..."
          autocomplete="off"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50 placeholder:text-slate-500"
        />
        <ul id="personaje-dropdown"
          class="absolute z-50 mt-1 hidden w-full rounded-xl border border-white/10 bg-slate-900 shadow-xl overflow-hidden">
        </ul>
        <!-- Tags seleccionados -->
        <div id="personaje-tags" class="mt-2 flex flex-wrap gap-1.5"></div>
      </div>

      <!-- Relaciones (autocomplete + tags) -->
      <div class="relative">
        <label class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Relaciones
        </label>
        <input
          id="filter-relacion-input"
          type="text"
          placeholder="Buscar relación..."
          autocomplete="off"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50 placeholder:text-slate-500"
        />
        <ul id="relacion-dropdown"
          class="absolute z-50 mt-1 hidden w-full rounded-xl border border-white/10 bg-slate-900 shadow-xl overflow-hidden">
        </ul>
        <!-- Tags seleccionados -->
        <div id="relacion-tags" class="mt-2 flex flex-wrap gap-1.5"></div>
      </div>

      <!-- Ordenar por -->
      <div>
        <label for="filter-orden"
          class="mb-2 block text-xs font-semibold uppercase tracking-wider text-slate-400">
          Ordenar por
        </label>
        <select id="filter-orden"
          class="w-full rounded-xl border border-white/10 bg-slate-950/70 px-4 py-3 text-sm text-slate-200 outline-none transition focus:border-pink-500/50">
          <option value="capitulos">Más capítulos</option>
          <option value="reciente">Más recientes</option>
          <option value="titulo">Título A-Z</option>
        </select>
      </div>

      <!-- Aplicar filtros -->
      <button
        id="apply-filters"
        class="w-full rounded-xl bg-gradient-to-r from-pink-500 to-orange-500 px-4 py-3 text-sm font-semibold text-white transition hover:opacity-90 active:scale-95"
      >
        Aplicar filtros
      </button>

      <!-- Limpiar filtros -->
      <button
        id="clear-filters"
        class="w-full rounded-xl border border-white/10 bg-white/[0.03] px-4 py-3 text-sm font-medium text-slate-300 transition hover:border-pink-500/30 hover:bg-pink-500/10 hover:text-pink-300"
      >
        Limpiar filtros
      </button>

    </div>
  </div>
</aside>

<!-- Datos para el script -->
<script
  id="filter-data"
  type="application/json"
  set:html={JSON.stringify({ autores, generos, relaciones, clasificaciones, personajes })}
/>

<script>
  // ── Datos ────────────────────────────────────────────────────────────────
  const raw = document.getElementById('filter-data')!.textContent!;
  const DATA: {
    autores: string[];
    generos: string[];
    relaciones: string[];
    clasificaciones: string[];
    personajes: string[];
  } = JSON.parse(raw);

  // ── Toggle panel ─────────────────────────────────────────────────────────
  const toggle   = document.getElementById('filter-toggle')!;
  const body     = document.getElementById('filter-body')!;
  const chevron  = document.getElementById('filter-chevron')!;
  body.style.maxHeight = body.scrollHeight + 'px';

  toggle.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    body.style.maxHeight  = isOpen ? '0px' : body.scrollHeight + 'px';
    chevron.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  // ── Helpers de autocompletado ────────────────────────────────────────────
  function normalize(str: string) {
    return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  /** Autocomplete de campo único (autor, género, clasificación) */
  function setupSingleAutocomplete(
    inputId: string,
    hiddenId: string,
    dropdownId: string,
    items: string[]
  ) {
    const input    = document.getElementById(inputId)    as HTMLInputElement;
    const hidden   = document.getElementById(hiddenId)   as HTMLInputElement;
    const dropdown = document.getElementById(dropdownId) as HTMLUListElement;

    function renderDropdown(q: string) {
      const matches = q
        ? items.filter(i => normalize(i).includes(normalize(q))).slice(0, 8)
        : [];
      dropdown.innerHTML = '';
      if (!matches.length) { dropdown.classList.add('hidden'); return; }
      matches.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        li.className = 'px-4 py-2.5 text-sm text-slate-200 cursor-pointer hover:bg-pink-500/20 hover:text-pink-300 transition';
        li.addEventListener('mousedown', e => {
          e.preventDefault();
          input.value  = item;
          hidden.value = item;
          dropdown.classList.add('hidden');
        });
        dropdown.appendChild(li);
      });
      dropdown.classList.remove('hidden');
    }

    input.addEventListener('input', () => {
      hidden.value = '';      // Se limpia hasta que seleccionen
      renderDropdown(input.value);
    });
    input.addEventListener('focus', () => renderDropdown(input.value));
    input.addEventListener('blur',  () => setTimeout(() => dropdown.classList.add('hidden'), 150));
  }

  /** Autocomplete de tags múltiples (personajes, relaciones) */
  function setupMultiTagAutocomplete(
    inputId: string,
    dropdownId: string,
    tagsContainerId: string,
    items: string[],
    stateKey: string
  ) {
    const input    = document.getElementById(inputId)         as HTMLInputElement;
    const dropdown = document.getElementById(dropdownId)      as HTMLUListElement;
    const tagsDiv  = document.getElementById(tagsContainerId) as HTMLDivElement;
    const selected = new Set<string>();

    // Exponer estado al exterior
    (window as any)[stateKey] = selected;

    function addTag(item: string) {
      if (selected.has(item)) return;
      selected.add(item);
      renderTags();
      input.value = '';
      dropdown.classList.add('hidden');
      // Recalcular maxHeight porque creció el panel
      body.style.maxHeight = body.scrollHeight + 'px';
    }

    function removeTag(item: string) {
      selected.delete(item);
      renderTags();
      body.style.maxHeight = body.scrollHeight + 'px';
    }

    function renderTags() {
      tagsDiv.innerHTML = '';
      selected.forEach(item => {
        const span = document.createElement('span');
        span.className = 'inline-flex items-center gap-1 rounded-full border border-pink-500/40 bg-pink-500/10 px-2.5 py-1 text-xs text-pink-300';
        span.innerHTML = `${item} <button type="button" class="ml-0.5 opacity-60 hover:opacity-100 text-pink-200 leading-none" data-remove="${item}">×</button>`;
        span.querySelector('button')!.addEventListener('click', () => removeTag(item));
        tagsDiv.appendChild(span);
      });
    }

    function renderDropdown(q: string) {
      const matches = q
        ? items.filter(i => normalize(i).includes(normalize(q)) && !selected.has(i)).slice(0, 8)
        : [];
      dropdown.innerHTML = '';
      if (!matches.length) { dropdown.classList.add('hidden'); return; }
      matches.forEach(item => {
        const li = document.createElement('li');
        li.textContent = item;
        li.className = 'px-4 py-2.5 text-sm text-slate-200 cursor-pointer hover:bg-pink-500/20 hover:text-pink-300 transition';
        li.addEventListener('mousedown', e => { e.preventDefault(); addTag(item); });
        dropdown.appendChild(li);
      });
      dropdown.classList.remove('hidden');
    }

    input.addEventListener('input',  () => renderDropdown(input.value));
    input.addEventListener('focus',  () => renderDropdown(input.value));
    input.addEventListener('blur',   () => setTimeout(() => dropdown.classList.add('hidden'), 150));
    input.addEventListener('keydown', e => {
      if (e.key === 'Enter') {
        e.preventDefault();
        const first = dropdown.querySelector('li');
        if (first) first.dispatchEvent(new MouseEvent('mousedown'));
      }
    });
  }

  // ── Inicializar autocompletados ───────────────────────────────────────────
  setupSingleAutocomplete('filter-autor-input',          'filter-autor',          'autor-dropdown',          DATA.autores);
  setupSingleAutocomplete('filter-genero-input',         'filter-genero',         'genero-dropdown',         DATA.generos);
  setupSingleAutocomplete('filter-clasificacion-input',  'filter-clasificacion',  'clasificacion-dropdown',  DATA.clasificaciones);
  setupMultiTagAutocomplete('filter-personaje-input', 'personaje-dropdown', 'personaje-tags', DATA.personajes, 'selectedPersonajes');
  setupMultiTagAutocomplete('filter-relacion-input',  'relacion-dropdown',  'relacion-tags',  DATA.relaciones, 'selectedRelaciones');

  // ── Aplicar filtros ───────────────────────────────────────────────────────
  document.getElementById('apply-filters')!.addEventListener('click', () => {
    const filters = {
      autor:          (document.getElementById('filter-autor')          as HTMLInputElement).value,
      genero:         (document.getElementById('filter-genero')         as HTMLInputElement).value,
      estado:         (document.getElementById('filter-estado')         as HTMLSelectElement).value,
      clasificacion:  (document.getElementById('filter-clasificacion')  as HTMLInputElement).value,
      orden:          (document.getElementById('filter-orden')          as HTMLSelectElement).value,
      personajes:     [...((window as any).selectedPersonajes as Set<string>)],
      relaciones:     [...((window as any).selectedRelaciones as Set<string>)],
    };
    document.dispatchEvent(new CustomEvent('fanfic:filter', { detail: filters }));
  });

  // ── Limpiar filtros ───────────────────────────────────────────────────────
  document.getElementById('clear-filters')!.addEventListener('click', () => {
    // Inputs de texto
    ['filter-autor-input','filter-genero-input','filter-clasificacion-input',
     'filter-personaje-input','filter-relacion-input'].forEach(id => {
      (document.getElementById(id) as HTMLInputElement).value = '';
    });
    // Hidden
    ['filter-autor','filter-genero','filter-clasificacion'].forEach(id => {
      (document.getElementById(id) as HTMLInputElement).value = '';
    });
    // Select
    (document.getElementById('filter-estado') as HTMLSelectElement).value = '';
    (document.getElementById('filter-orden')  as HTMLSelectElement).value = 'capitulos';

    // Limpiar sets de tags
    ((window as any).selectedPersonajes as Set<string>).clear();
    ((window as any).selectedRelaciones as Set<string>).clear();
    document.getElementById('personaje-tags')!.innerHTML = '';
    document.getElementById('relacion-tags')!.innerHTML  = '';

    // Disparar evento para resetear grid
    document.dispatchEvent(new CustomEvent('fanfic:filter', { detail: {} }));

    body.style.maxHeight = body.scrollHeight + 'px';
  });
</script>