---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/buscar", label: "Buscar" },
  { href: "/biblioteca", label: "Biblioteca" },
];
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/75 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 transition-opacity hover:opacity-90">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-pink-500 to-orange-500 text-lg shadow-lg shadow-pink-500/20">
        📖
      </div>

      <div class="flex flex-col">
        <span class="text-lg font-bold tracking-wide text-white" style="font-family:'Cinzel', serif;">
          Fanfic
        </span>

        <span class="text-xs text-slate-400">
          Leer fics
        </span>
      </div>
    </a>

    <!-- Navegación -->
    <nav class="flex items-center gap-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`rounded-xl px-4 py-2 text-sm font-medium transition-all duration-200 ${
              currentPath === link.href
                ? "bg-pink-500/15 text-white ring-1 ring-pink-500/30"
                : "text-slate-400 hover:bg-white/5 hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

  </div>
</header>