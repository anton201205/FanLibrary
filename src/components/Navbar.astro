---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/buscar", label: "Buscar" },
  { href: "/biblioteca", label: "Biblioteca" },
];
---

<header class="sticky top-0 z-50 border-b border-white/5 bg-slate-950/75 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 py-4">

    <a href="/" class="flex items-center gap-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-pink-500 to-orange-500">
        📖
      </div>

      <div>
        <span class="block text-lg font-bold text-white">
          Fanfic
        </span>

        <span class="text-xs text-slate-400">
          Leer fics
        </span>
      </div>
    </a>

    <!-- Botón móvil -->
    <button
      id="menu-toggle"
      class="flex h-10 w-10 items-center justify-center rounded-lg text-white md:hidden"
      aria-label="Abrir menú"
    >
      ☰
    </button>

    <!-- Desktop -->
    <nav class="hidden md:flex items-center gap-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`rounded-xl px-4 py-2 text-sm font-medium transition ${
              currentPath === link.href
                ? "bg-pink-500/15 text-white ring-1 ring-pink-500/30"
                : "text-slate-400 hover:bg-white/5 hover:text-white"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

  </div>

  <!-- Menú móvil -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-white/5 bg-slate-950 md:hidden"
  >
    <div class="flex flex-col p-3">
      {
        links.map((link) => (
          <a
            href={link.href}
            class={`rounded-xl px-4 py-3 text-sm ${
              currentPath === link.href
                ? "bg-pink-500/15 text-white"
                : "text-slate-300"
            }`}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");

  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>